# npm Security Configuration
# Enforces supply chain security best practices

# Exact version pinning (no ^ or ~ when running npm install)
save-exact=true

# Lock file consistency
package-lock=true

# 7-DAY RELEASE COOLDOWN (npm 11.10.0+)
# Only install packages published at least 7 days ago
# Protects against supply chain attacks in newly published malicious packages
# Value in days: 7
min-release-age=7

# Disable automatic peer dependency installation
# Prevents unexpected dependency additions
legacy-peer-deps=true

# BLOCK GIT DEPENDENCIES (npm 11.10.0+)
# Prevents git://, file://, and other non-registry sources
# Reduces attack surface by ensuring all packages come from npm registry
# Will become default in npm 12
allow-git=none
