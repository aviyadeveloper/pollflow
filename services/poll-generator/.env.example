# Example environment variables for local testing
# Copy to .env and fill with real values

# ============================================================
# AWS Secrets Manager ARNs
# ============================================================
RDS_SECRET_ARN=<secret-arn-for-rds-credentials>
OPENROUTER_SECRET_ARN=<secret-arn-for-openrouter-key>
NEWSAPI_SECRET_ARN=<secret-arn-for-newsapi-key>

# ============================================================
# AWS Configuration
# ============================================================
AWS_REGION=eu-west-3

# ============================================================
# RDS Connection Details
# ============================================================
# These are typically output by Terraform (see infra/.ci/rds-config.env)
# RDS_SECRET_ARN above contains only username/password
RDS_HOST=<rds-instance-hostname>
RDS_PORT=5432
RDS_DBNAME=pollflow

# ============================================================
# Scheduling Configuration
# ============================================================
# Lambda runs every 2 hours (12 times/day)
# 12 runs × 24 polls = 288 polls/day = 1 poll every 5 minutes (24/7)
# 
# Benefits of 2-hour cadence:
# - Breaking news responsiveness (max 2 hours behind instead of 24)
# - Smaller batches (easier debugging, better error recovery)
# - Same total cost (288 LLM calls/day regardless of cadence)
SCHEDULE_WINDOW_HOURS=2
TARGET_POLLS_PER_RUN=24

# ============================================================
# News Fetching Configuration
# ============================================================
# Fetch ~35 articles to generate ~30 raw polls
# After quality gates: ~24 polls ready for scheduling
ARTICLE_COUNT=35

# ============================================================
# Quality Gates Configuration
# ============================================================
# TF-IDF cosine similarity threshold for deduplication (0.0-1.0)
# 0.8 = strict (only very similar polls flagged as duplicates)
# 0.6 = moderate
# 0.4 = lenient
SIMILARITY_THRESHOLD=0.8

# ============================================================
# Poll Lifecycle Configuration
# ============================================================
# How long each poll remains active for voting (in hours)
# After this duration, poll-broker service will close the poll
POLL_DURATION_HOURS=12

# ============================================================
# LLM Configuration
# ============================================================
# Recommended: google/gemma-4-26b-a4b-it (paid tier, reliable, low cost)
LLM_MODEL=google/gemma-4-26b-a4b-it
