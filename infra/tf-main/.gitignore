# Terraform state files
*.tfstate
*.tfstate.*

# Terraform directory
.terraform/
.terraform.lock.hcl

# SSH keys (generated by bastion module)
.keys/
*.pem

# Crash log files
crash.log
crash.*.log

# Variable files with sensitive data
*.tfvars
*.tfvars.json

# CLI configuration files
.terraformrc
terraform.rc
